  "keyFeatures": [
    "High-performance ANN vector search with HNSW, IVF, DiskANN, SCANN index support",
    "Distributed cloud-native architecture with horizontal scaling",
    "Hybrid search combining dense vectors, sparse vectors, and full-text BM25 search",
    "GPU acceleration with NVIDIA CAGRA support",
    "Multi-tenancy with database, collection, and partition-level isolation",
    "Role-Based Access Control (RBAC) and TLS encryption",
    "Real-time streaming data ingestion with strong consistency guarantees",
    "Hot/cold tiered storage for cost-effective data management",
    "Milvus Lite for local development and Standalone mode for single-node deployment"
  ],
  "publicApiSurface": [
    "CreateCollection / DropCollection / DescribeCollection / ShowCollections",
    "Insert / Upsert / Delete / Flush",
    "Search (ANN vector search with metadata filtering)",
    "Query (scalar filter queries)",
    "HybridSearch (multi-vector / sparse+dense search)",
    "CreateIndex / DescribeIndex / DropIndex",
    "CreatePartition / DropPartition / LoadPartition",
    "CreateDatabase / DropDatabase",
    "CreateUser / CreateRole / GrantPrivilege (RBAC)",
    "LoadCollection / ReleaseCollection",
    "BulkInsert (batch data import)",
    "GetFlushState / GetLoadState"
  ]
